{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "uia_legacy_invoke",
  "description": "Invoke a UI element via LegacyIAccessiblePattern.DoDefaultAction (MSAA).",
  "type": "object",
  "properties": {
    "api_key": {
      "type": "string",
      "description": "API key for authentication."
    },
    "target": {
      "$ref": "target.json",
      "description": "Element selector (supports all UIA + MSAA strategies)."
    }
  },
  "required": ["target"],
  "additionalProperties": false,
  "examples": [
    { "target": { "by": "legacy_name", "value": "Example Bank Checking" } },
    { "target": { "by": "child_id", "value": "1" } },
    { "target": { "by": "hwnd", "value": "0x1001" } }
  ]
}
